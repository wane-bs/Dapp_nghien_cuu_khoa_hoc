# VinaLib-Vault Backend — Environment Variables Template
# Copy file này thành .env và điền giá trị thực

# Blockchain Admin Private Key
# Dùng Hardhat Account #0 cho local dev
# KHÔNG BAO GIỜ commit .env vào git
ADMIN_PRIVATE_KEY=your_private_key_here

# Server
NODE_ENV=local
PORT=3000

# Blockchain RPC URL
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
